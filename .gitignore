# Directories with large map files and GeoJSON data
Maps/
# Geojson/  # Commented to allow data/geojson/ to be tracked

# Ignore all data directory EXCEPT database/seeds/ (frontend/backend use database, not these files)
data/
!database/seeds/

# Ignore scripts directory EXCEPT database/seeds/scripts/ (utility scripts for data import/migration, not needed to run app)
scripts/
!database/seeds/scripts/

# Ignore DEM rasters and data cache
data/*.tif
data/*.tiff
data/dem_elevation.tif

# Node modules
node_modules/

# System files
.DS_Store

# Environment variables
.env
.env.local
